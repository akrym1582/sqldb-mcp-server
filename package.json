{
  "name": "@akrym1582/sqldb-mcp-server",
  "version": "0.0.1",
  "description": "MCP server for SQL database access (MSSQL, PostgreSQL, MySQL)",
  "main": "dist/mcp/server.js",
  "bin": {
    "sqldb-mcp-server": "dist/mcp/server.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcp/server.js",
    "dev": "ts-node src/mcp/server.ts",
    "test": "jest --forceExit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akryk7316/sqldb-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sql",
    "mssql",
    "postgresql",
    "mysql",
    "database",
    "llm",
    "ai"
  ],
  "author": "akrym1582",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/akryk7316/sqldb-mcp-server/issues"
  },
  "homepage": "https://github.com/akryk7316/sqldb-mcp-server#readme",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "coverageDirectory": "coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.20.0",
    "pg-cursor": "^2.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mssql": "^9.1.9",
    "@types/node": "^25.5.0",
    "@types/node-sql-parser": "^1.0.0",
    "@types/pg": "^8.18.0",
    "@types/pg-cursor": "^2.7.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
