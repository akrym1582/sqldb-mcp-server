# Database type: mssql | postgresql | mysql
DB_TYPE=mssql
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=xxx
DB_NAME=test
#
# Optional: encrypt the database connection.
# - MSSQL: defaults to true and trusts the server certificate.
# - PostgreSQL: defaults to true, tries SSL first, and falls back to plain if SSL is unavailable.
# - MySQL: defaults to false; set to true to enable TLS and trust the server certificate.
DB_ENCRYPT=true

# Optional: query timeout in milliseconds (default: 30000)
DB_QUERY_TIMEOUT=30000

# Optional: export query timeout in milliseconds (default: 300000 = 5 minutes)
# Use a longer value for large exports that stream a lot of rows.
EXPORT_QUERY_TIMEOUT=300000

# Optional: cache TTL in seconds (default: 60)
CACHE_TTL=60
